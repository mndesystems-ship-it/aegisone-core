        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="duplicate keys" enabled="true">
            <stringProp name="HTTPSampler.domain">127.0.0.1</stringProp>
